{
	"imports": {
		"@noble/curves": "jsr:@noble/curves@1.9.0",
		"@noble/hashes": "jsr:@noble/hashes@1.8.0",
		"@noble/secp256k1": "jsr:@noble/secp256k1@2.3.0",
		"@std/assert": "jsr:@std/assert@^1.0.19",
		"@std/async": "jsr:@std/async@1.0.14",
		"@std/bytes": "jsr:@std/bytes@1.0.6",
		"@std/encoding": "jsr:@std/encoding@1.0.10",
		"@std/fs": "jsr:@std/fs@1.0.19",
		"@std/path": "jsr:@std/path@1.1.2",
		"@std/streams": "jsr:@std/streams@1.0.12",
		"~/": "./app/"
	},
	"tasks": {
		"cache": "deno cache ./app/main.ts",
		"start": "deno run -A ./app/main.ts",
		"check": "deno check app && deno lint app"
	},
	"unstable": ["raw-imports"],
	"compilerOptions": {
		"lib": ["deno.ns", "deno.window", "esnext"],
		"strict": true,
		"noUncheckedIndexedAccess": true
	},
	"fmt": {
		"lineWidth": 120,
		"indentWidth": 4,
		"useTabs": true
	},
	"lint": {
		"rules": {
			"exclude": ["no-namespace", "no-explicit-any", "ban-types"],
			"include": ["no-slow-types"]
		}
	}
}
