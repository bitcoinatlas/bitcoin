{
	"imports": {
		"@db/sqlite": "jsr:@db/sqlite@^0.13.0",
		"@noble/curves": "jsr:@noble/curves@1.9.0",
		"@noble/hashes": "jsr:@noble/hashes@1.8.0",
		"@noble/secp256k1": "jsr:@noble/secp256k1@2.3.0",
		"@nomadshiba/codec": "jsr:@nomadshiba/codec@0.3.0-preview.12",
		"@purifyjs/core": "jsr:@purifyjs/core@^0.4.0",
		"@std/assert": "jsr:@std/assert@^1.0.19",
		"@std/async": "jsr:@std/async@^1.3.0",
		"@std/bytes": "jsr:@std/bytes@1.0.6",
		"@std/encoding": "jsr:@std/encoding@1.0.10",
		"@std/fs": "jsr:@std/fs@1.0.19",
		"@std/http": "jsr:@std/http@^1.1.0",
		"@std/path": "jsr:@std/path@1.1.2",
		"@std/streams": "jsr:@std/streams@1.0.12",
		"@std/uuid": "jsr:@std/uuid@^1.1.1",
		"~/": "./app/"
	},
	"tasks": {
		"cache": "deno cache ./app/main.ts",
		"start": "deno run -A ./app/main.ts",
		"inspect": "deno run -A --inspect-brk ./app/main.ts",
		"dev": "deno task build && (deno run -A --watch ./app/main.ts & deno task dev:build)",
		"build": "deno bundle --output=app/ui/dist/app.js app/ui/app.ts",
		"dev:build": "deno bundle --output=app/ui/dist/app.js app/ui/app.ts --watch",
		"test": "deno test --allow-env --allow-read --allow-write --allow-ffi",
		"check": "deno check && deno lint && deno task test"
	},
	"unstable": ["raw-imports", "kv"],
	"compilerOptions": {
		"lib": [
			"deno.ns",
			"deno.window",
			"deno.unstable",
			"esnext",
			"dom",
			"dom.iterable"
		],
		"strict": true,
		"noUncheckedIndexedAccess": true
	},
	"fmt": {
		"lineWidth": 120,
		"indentWidth": 4,
		"useTabs": true
	},
	"lint": {
		"rules": {
			"exclude": [
				"no-namespace",
				"no-explicit-any",
				"ban-types",
				"require-await"
			],
			"include": ["no-slow-types"]
		}
	}
}
